# Copy to .env.docker if you want compose-specific overrides.
APP_PORT=5000

# Pin deployment image tag (for predictable rollouts). Examples: latest, v0.1
ANKI_JISHO2ANKI_IMAGE_TAG=latest

# Optional presets/default behavior.
# ANKI_JISHO2ANKI_PRESET=balanced

# AnkiConnect URL. Choose based on your OS:
# - Linux: http://127.0.0.1:8765 (direct localhost)
# - Windows/Mac: http://host.docker.internal:8765 (Docker Desktop bridge)
# PIP_TIMEOUT=15
