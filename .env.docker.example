# Copy to .env.docker if you want compose-specific overrides.
APP_PORT=5000

# Pin deployment image tag (for predictable rollouts). Examples: latest, v0.1
ANKI_JISHO2ANKI_IMAGE_TAG=latest

# Optional presets/default behavior.
# ANKI_JISHO2ANKI_PRESET=balanced

# With Linux host networking, localhost reaches desktop AnkiConnect directly.
ANKI_JISHO2ANKI_ANKI_URL=http://127.0.0.1:8765

# Where TSV output is written inside the container.
ANKI_JISHO2ANKI_OUTPUT_PATH=/app/output/anki_import.tsv

# Optional pip source overrides for Docker image builds.
# PIP_INDEX_URL=https://pypi.org/simple
# PIP_EXTRA_INDEX_URL=
# PIP_RETRIES=1
# PIP_TIMEOUT=15
