# Copy this file to .env and customize.
# Any ANKI_AUTOFILLER_* value can be overridden by CLI flags or form inputs.

ANKI_AUTOFILLER_INPUT=words.txt
ANKI_AUTOFILLER_OUTPUT_PATH=anki_import.tsv
ANKI_AUTOFILLER_INCLUDE_HEADER=true
ANKI_AUTOFILLER_PAUSE_SECONDS=0
ANKI_AUTOFILLER_MAX_WORKERS=6
ANKI_AUTOFILLER_INTERACTIVE_REVIEW=false
ANKI_AUTOFILLER_CANDIDATE_LIMIT=3
ANKI_AUTOFILLER_SENTENCE_COUNT=2
ANKI_AUTOFILLER_SEPARATE_SENTENCE_CARDS=false
ANKI_AUTOFILLER_INCLUDE_SENTENCES=true
ANKI_AUTOFILLER_INCLUDE_PITCH_ACCENT=true
ANKI_AUTOFILLER_ANKI_CONNECT=true
ANKI_AUTOFILLER_ANKI_URL=http://127.0.0.1:8765
ANKI_AUTOFILLER_DECK_NAME=Example
ANKI_AUTOFILLER_MODEL_NAME=Japanese (Basic & Reversed)
ANKI_AUTOFILLER_FIELD_WORD=Expression
ANKI_AUTOFILLER_FIELD_MEANING=Meaning
ANKI_AUTOFILLER_FIELD_READING=Reading
ANKI_AUTOFILLER_TAGS=
ANKI_AUTOFILLER_ALLOW_DUPLICATES=false
ANKI_AUTOFILLER_SENTENCE_DECK_NAME=Example::Examples
ANKI_AUTOFILLER_SENTENCE_MODEL_NAME=Basic
ANKI_AUTOFILLER_SENTENCE_FRONT_FIELD=Front
ANKI_AUTOFILLER_SENTENCE_BACK_FIELD=Back
ANKI_AUTOFILLER_VITE_DEV_SERVER_URL=
